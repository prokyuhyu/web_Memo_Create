generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum EntityType {
  FILE
  SCHEDULE
  NOTE
}

enum SyncAction {
  CREATE
  UPDATE
  DELETE
  CONFLICT
}

enum ResolvedBy {
  CLIENT
  SERVER
  PENDING
}

enum TriggerType {
  TIME_BASED
  CONDITION_BASED
  EVENT_BASED
}

// ─── Auth ─────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  refreshTokens RefreshToken[]
  files         File[]
  schedules     Schedule[]
  notes         Note[]
  syncLogs      SyncLog[]
  macros        Macro[]
  chatRooms     ChatRoomParticipant[]
  sentMessages  ChatMessage[]
  comments      Comment[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Files ────────────────────────────────────────────────────────────────────

model File {
  id           String    @id @default(cuid())
  userId       String
  originalName String
  storedName   String
  mimeType     String
  size         Int
  path         String
  version      Int       @default(1)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Schedules ────────────────────────────────────────────────────────────────

model Schedule {
  id          String    @id @default(cuid())
  userId      String
  title       String
  description String?
  startAt     DateTime
  endAt       DateTime?
  notifyAt    DateTime?
  version     Int       @default(1)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Notes ────────────────────────────────────────────────────────────────────

model Note {
  id        String    @id @default(cuid())
  userId    String
  title     String
  body      String
  tags      String[]
  isPublic  Boolean   @default(false)
  version   Int       @default(1)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments Comment[]

  @@index([userId])
}

// ─── Sync ─────────────────────────────────────────────────────────────────────

model SyncLog {
  id            String     @id @default(cuid())
  userId        String
  entityType    EntityType
  entityId      String
  action        SyncAction
  clientVersion Int
  serverVersion Int
  resolvedBy    ResolvedBy @default(PENDING)
  syncedAt      DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([entityType, entityId])
}

// ─── Chat ─────────────────────────────────────────────────────────────────────

model ChatRoom {
  id           String    @id @default(cuid())
  name         String?
  isPersonal   Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  participants ChatRoomParticipant[]
  messages     ChatMessage[]

  @@index([updatedAt])
}

model ChatRoomParticipant {
  id       String   @id @default(cuid())
  roomId   String
  userId   String
  joinedAt DateTime @default(now())
  room     ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([userId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  roomId    String
  senderId  String
  content   String
  createdAt DateTime @default(now())
  room      ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([roomId, createdAt])
}

// ─── Macros ───────────────────────────────────────────────────────────────────

model Macro {
  id            String      @id @default(cuid())
  userId        String
  name          String
  triggerType   TriggerType
  triggerConfig Json
  actionType    String
  actionConfig  Json
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Comments ─────────────────────────────────────────────────────────────────

model Comment {
  id        String   @id @default(cuid())
  noteId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  note Note @relation(fields: [noteId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([noteId])
  @@index([userId])
}
